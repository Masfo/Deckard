	inline constexpr std::uint64_t kComposeBit = std::uint64_t{1} << 63;
	inline constexpr std::uint64_t kCpMask     = 0x1F'FFFFu;

	[[nodiscard]] constexpr auto field_a(std::uint64_t e) noexcept -> char32_t
	{
		return static_cast<char32_t>((e >> 42) & kCpMask);
	}

	[[nodiscard]] constexpr auto field_b(std::uint64_t e) noexcept -> char32_t
	{
		return static_cast<char32_t>((e >> 21) & kCpMask);
	}

	[[nodiscard]] constexpr auto field_c(std::uint64_t e) noexcept -> char32_t { return static_cast<char32_t>(e & kCpMask); }

