	inline constexpr std::size_t compose_offset = []() constexpr
	{
		for (std::size_t i = 0; i < std::size(table); ++i)
			if (table[i] & kComposeBit)
				return i;
		return std::size(table);
	}();
	export constexpr std::size_t table_size = sizeof(table) / sizeof(table[0]);

