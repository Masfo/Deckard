	static_assert(table[compose_offset] & kComposeBit, "compose_offset points to non-compose entry");
	static_assert(compose_offset == 0 or not(table[compose_offset - 1] & kComposeBit),
				  "compose_offset is too late — entry before it also has compose bit");

	inline constexpr auto decomp_span  = std::span{table, compose_offset};
	inline constexpr auto compose_span = std::span{table + compose_offset, table_size - compose_offset};


